# ─────────────────────────────────────────────────────────────────────────────
# supertrainer environment variables
# Copy to .env.local (apps/web reads it) and fill in real values.
# NEXT_PUBLIC_* vars are exposed to the browser — never put secrets in them.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (Phase 0.2 provisions the project; local dev uses `supabase start`)
# Project URL — Supabase dashboard → Settings → API. Local: http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=
# Anon/publishable key — safe for the browser; RLS enforces all access
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY, bypasses RLS. Used by packages/db service client.
SUPABASE_SERVICE_ROLE_KEY=

# ── App origin (auth email/OAuth redirects)
# Public base URL of this deployment. Auth magic-link and Google redirects are
# built from it — if unset in production, sign-in links point at localhost and
# break. Local dev may omit it (falls back to http://localhost:3000).
NEXT_PUBLIC_APP_URL=

# ── Platform domain (branded trainer subdomains, P1.2)
# Apex the trainer handle hangs off: {slug}.<platform> and shown in the brand
# handle preview. Middleware rewrites branded subdomains into /c/{slug}. Local
# dev may omit it (subdomains don't resolve on localhost; use /c/{slug}).
NEXT_PUBLIC_PLATFORM_DOMAIN=

# ── Anthropic (packages/ai — all AI calls route through modelRouter)
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Langfuse LLM tracing (packages/ai wraps every Claude call — see tracing.ts)
# Unset both keys → tracing no-ops. Cost is computed by Langfuse from the model
# + token usage, so add the Haiku/Sonnet/Opus prices in your Langfuse project
# (Settings → Models) for cost to appear on generations.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Cloud: https://cloud.langfuse.com — or your self-hosted URL
LANGFUSE_HOST=

# ── Sentry error tracking (Phase 0.5)
# Runtime DSNs — unset → the SDK initializes but sends nothing.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Build-time only (source-map upload + release tagging in next.config.ts).
# Set these in the Vercel/CI build environment, NOT the browser. All three must
# be present for withSentryConfig to upload source maps.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── PostHog product analytics (Phase 0.5)
# Same key powers browser capture (posthog-js) and server capture (posthog-node,
# which also writes the events table). Unset → all capture no-ops.
NEXT_PUBLIC_POSTHOG_KEY=
# e.g. https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=

# ── Resend transactional email (Phase 1.7 invites; digests/receipts later)
# Unset → email sending no-ops and invites fall back to copy-link. RESEND_FROM
# must be a verified sender/domain on your Resend account.
RESEND_API_KEY=
RESEND_FROM=

# ── Web push / VAPID (Phase 2.4 captures subscriptions; Phase 6 sends)
# Generate a keypair with: npx web-push generate-vapid-keys
# Unset → the walkthrough still records the client's channel choice, but no push
# subscription can be created (Phase 6 falls back to the email digest).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI sent to push services with each push (Phase 6.2). Defaults to a
# mailto: if unset. NEXT_PUBLIC_APP_URL is the base for digest email deep links.
VAPID_SUBJECT=
NEXT_PUBLIC_APP_URL=

# ── Cloudflare Turnstile (Phase 2.1 teaser bot protection)
# Guards the public /c/{slug}/start endpoint (it drives paid AI in P2.2). Both
# unset → verification is skipped (dev/preview/CI) and the funnel still works;
# set both in production. Site key is browser-exposed; secret key is server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Lead rate-limit IP hashing (Phase 2 backstop)
# Keys the per-source/day DoS sublimit on an HMAC of the client IP (never the
# raw address). Unset → ip_hash is null and the per-IP sublimit is skipped
# (Turnstile + per-email + per-org limits still apply). Server-only secret.
LEAD_IP_HASH_SECRET=

# ── Cron trigger secret (Phase 2 backstop: interview stall nudges)
# Vercel Cron sends `Authorization: Bearer $CRON_SECRET` to /api/cron/*. The
# endpoint fails CLOSED — unset ⇒ it refuses to run (503). Set in production and
# in apps/web/.env.local for the cron e2e. Server-only secret.
CRON_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Payments — Stripe Connect (Phase 8)
# TEST MODE ONLY in dev/preview/CI. All keys unset ⇒ every Stripe call is
# gated off: onboarding/checkout/dunning render a "payments not configured"
# state, the webhook route 503s, and the LIVE-Stripe e2e specs SKIP (the merge
# gate mocks the Stripe client + injects webhook events, so CI stays 100%
# deterministic — mirror of the ANTHROPIC_API_KEY live-AI gating). Never put a
# live-mode (sk_live_*) key here; a PreToolUse hook blocks live-mode CLI use.
# ── Platform secret key — SERVER ONLY. Test: sk_test_… (Stripe dashboard → API keys)
STRIPE_SECRET_KEY=
# ── Publishable key — browser-safe (Checkout/Elements). Test: pk_test_…
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# ── Webhook signing secret — SERVER ONLY. Verifies /api/webhooks/stripe payloads.
# Local: `stripe listen --forward-to localhost:3000/api/webhooks/stripe` prints a
# whsec_… — paste it here. Prod: dashboard → Webhooks → signing secret.
STRIPE_WEBHOOK_SECRET=
# ── Connect: application fee taken on every client payment (percent). Business
# rule §11 — stay well under TrueCoach's 5%. Default 2.5 if unset.
STRIPE_APPLICATION_FEE_PERCENT=2.5
# ── Platform base-fee Price ids (the trainer's SaaS subscription — seat tiers per
# §11: ≤20 / ≤50 / ≤100 / unlimited). Test-mode price_… ids for each seat band.
# Unset ⇒ base-fee enrolment is skipped (Connect + client billing still work).
STRIPE_PLATFORM_PRICE_SEATS_20=
STRIPE_PLATFORM_PRICE_SEATS_50=
STRIPE_PLATFORM_PRICE_SEATS_100=
STRIPE_PLATFORM_PRICE_SEATS_UNLIMITED=
# ── Founder pricing / grace flag (Phase 8.6 beta cutover). "1" ⇒ existing orgs
# get the 60-day founder trial + founder pricing honored for life; unset ⇒
# standard 14-day trial. Superseded by the P9.3 feature flag when it ships.
NEXT_PUBLIC_FOUNDER_GRACE=

# ─────────────────────────────────────────────────────────────────────────────
# Scheduling — Cal.com (Phase 8.5, video-call tiers)
# Powers the monthly-call booking embed for tiers with video_calls_per_month>0.
# Unset ⇒ the call-booking card renders a "scheduling not configured" state and
# call credits are not decremented. Evaluate managed-user vs. hosted-embed at
# build time (simplest reliable path wins). Server-only API key.
CALCOM_API_KEY=
# Webhook signing secret for booking events (credit decrement). Fails closed.
CALCOM_WEBHOOK_SECRET=
