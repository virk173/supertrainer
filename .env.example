# ─────────────────────────────────────────────────────────────────────────────
# supertrainer environment variables
# Copy to .env.local (apps/web reads it) and fill in real values.
# NEXT_PUBLIC_* vars are exposed to the browser — never put secrets in them.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (Phase 0.2 provisions the project; local dev uses `supabase start`)
# Project URL — Supabase dashboard → Settings → API. Local: http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=
# Anon/publishable key — safe for the browser; RLS enforces all access
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY, bypasses RLS. Used by packages/db service client.
SUPABASE_SERVICE_ROLE_KEY=

# ── App origin (auth email/OAuth redirects)
# Public base URL of this deployment. Auth magic-link and Google redirects are
# built from it — if unset in production, sign-in links point at localhost and
# break. Local dev may omit it (falls back to http://localhost:3000).
NEXT_PUBLIC_APP_URL=

# ── Platform domain (branded trainer subdomains, P1.2)
# Apex the trainer handle hangs off: {slug}.<platform> and shown in the brand
# handle preview. Middleware rewrites branded subdomains into /c/{slug}. Local
# dev may omit it (subdomains don't resolve on localhost; use /c/{slug}).
NEXT_PUBLIC_PLATFORM_DOMAIN=

# ── Anthropic (packages/ai — all AI calls route through modelRouter)
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Langfuse LLM tracing (packages/ai wraps every Claude call — see tracing.ts)
# Unset both keys → tracing no-ops. Cost is computed by Langfuse from the model
# + token usage, so add the Haiku/Sonnet/Opus prices in your Langfuse project
# (Settings → Models) for cost to appear on generations.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Cloud: https://cloud.langfuse.com — or your self-hosted URL
LANGFUSE_HOST=

# ── Sentry error tracking (Phase 0.5)
# Runtime DSNs — unset → the SDK initializes but sends nothing.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Build-time only (source-map upload + release tagging in next.config.ts).
# Set these in the Vercel/CI build environment, NOT the browser. All three must
# be present for withSentryConfig to upload source maps.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── PostHog product analytics (Phase 0.5)
# Same key powers browser capture (posthog-js) and server capture (posthog-node,
# which also writes the events table). Unset → all capture no-ops.
NEXT_PUBLIC_POSTHOG_KEY=
# e.g. https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=

# ── Resend transactional email (Phase 1.7 invites; digests/receipts later)
# Unset → email sending no-ops and invites fall back to copy-link. RESEND_FROM
# must be a verified sender/domain on your Resend account.
RESEND_API_KEY=
RESEND_FROM=

# ── Web push / VAPID (Phase 2.4 captures subscriptions; Phase 6 sends)
# Generate a keypair with: npx web-push generate-vapid-keys
# Unset → the walkthrough still records the client's channel choice, but no push
# subscription can be created (Phase 6 falls back to the email digest).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Cloudflare Turnstile (Phase 2.1 teaser bot protection)
# Guards the public /c/{slug}/start endpoint (it drives paid AI in P2.2). Both
# unset → verification is skipped (dev/preview/CI) and the funnel still works;
# set both in production. Site key is browser-exposed; secret key is server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Lead rate-limit IP hashing (Phase 2 backstop)
# Keys the per-source/day DoS sublimit on an HMAC of the client IP (never the
# raw address). Unset → ip_hash is null and the per-IP sublimit is skipped
# (Turnstile + per-email + per-org limits still apply). Server-only secret.
LEAD_IP_HASH_SECRET=
